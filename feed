<script>
// ── Toast ──
function showToast(msg, dur) {
  var t = document.getElementById('toast');
  if (!t) return;
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._tid);
  t._tid = setTimeout(function() { t.classList.remove('show'); }, dur || 3000);
}

// ── Tema ──
(function() {
  var btn = document.getElementById('themeToggle');
  if (!btn) return;
  function applyTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    btn.textContent = t === 'dark' ? '🌙' : '☀️';
    localStorage.setItem('pflix_theme', t);
  }
  btn.addEventListener('click', function() {
    applyTheme(document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
  });
})();

// ── Hamburger ──
(function() {
  var btn = document.getElementById('hamburgerBtn'), menu = document.getElementById('mobileNavMenu');
  if (!btn || !menu) return;
  btn.addEventListener('click', function() {
    var open = menu.classList.toggle('open');
    btn.classList.toggle('open', open);
    btn.setAttribute('aria-expanded', open.toString());
  });
  menu.querySelectorAll('a').forEach(function(a) {
    a.addEventListener('click', function() { menu.classList.remove('open'); btn.classList.remove('open'); });
  });
  document.addEventListener('click', function(e) {
    if (!btn.contains(e.target) && !menu.contains(e.target)) { menu.classList.remove('open'); btn.classList.remove('open'); }
  });
})();

// ── Back to top ──
(function() {
  var btn = document.getElementById('backToTop');
  if (!btn) return;
  window.addEventListener('scroll', function() { btn.classList.toggle('visible', window.scrollY > 400); });
  btn.addEventListener('click', function() { window.scrollTo({ top: 0, behavior: 'smooth' }); });
})();

// ── Search ──
(function() {
  var overlay = document.getElementById('searchResultsOverlay');
  var grid = document.getElementById('searchResultsGrid');
  var label = document.getElementById('searchQueryLabel');
  var closeBtn = document.getElementById('searchResultsClose');
  var mobileToggle = document.getElementById('mobileSearchToggle');
  var mobileOverlay = document.getElementById('mobileSearchOverlay');
  var mobileClose = document.getElementById('mobileSearchClose');

  if (closeBtn) closeBtn.addEventListener('click', function() { overlay.classList.remove('active'); });
  if (mobileToggle && mobileOverlay) {
    mobileToggle.addEventListener('click', function() { mobileOverlay.classList.add('active'); document.getElementById('mobileSearchInput').focus(); });
    if (mobileClose) mobileClose.addEventListener('click', function() { mobileOverlay.classList.remove('active'); });
  }

  async function setupSearch() {
    try {
      var all = await PipocaAPI.getTodosConteudos();
      PipocaSearch.indexContent(all);
      function mkCard(item) {
        var d = document.createElement('div'); d.className = 'card';
        var page = item.isSerie ? 'serie.html' : 'filme.html';
        d.innerHTML = '<div class="card-thumb-wrap"><img class="card-thumb" src="' + (item.capa||'') + '" alt="' + item.nome + '" loading="lazy" onerror="this.src=\'https://placehold.co/300x450/13131a/333?text=Sem+Capa\'"><span class="card-badge">' + (item.isSerie ? 'Série' : 'Filme') + '</span><div class="card-play"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div></div><div class="card-info"><div class="card-name">' + item.nome + '</div><div class="card-meta-row"><span>' + (item.ano||'') + '</span></div></div>';
        d.addEventListener('click', function() { location.href = page + '?nome=' + encodeURIComponent(item.nome); });
        return d;
      }
      function doSearch(q) {
        if (!q || q.length < 2) { overlay.classList.remove('active'); return; }
        var res = PipocaSearch.search(q, 30);
        if (label) label.textContent = q;
        if (grid) { grid.innerHTML = ''; res.forEach(function(i) { grid.appendChild(mkCard(i)); }); }
        overlay.classList.add('active');
      }
      var deb = PipocaSearch.debounce(doSearch, 250);
      var dInput = document.getElementById('desktopSearchInput');
      var mInput = document.getElementById('mobileSearchInput');
      if (dInput) dInput.addEventListener('input', function(e) { deb(e.target.value); });
      if (mInput) mInput.addEventListener('input', function(e) { deb(e.target.value); });
    } catch(e) { console.warn('[Feed] Search setup failed:', e); }
  }
  setupSearch();
})();

// ── FEED INIT ──
async function initFeed() {
  var grid = document.getElementById('feedGrid');
  var empty = document.getElementById('feedEmpty');

  try {
    var noticias = await PipocaAPI.getFeedNoticias();
    grid.innerHTML = '';

    if (!noticias || !noticias.length) {
      empty.style.display = 'block';
      return;
    }

    noticias.forEach(function(n) {
      var card = document.createElement('article');
      card.className = 'feed-card';

      var imgHTML = n.imagemNoticia
        ? '<div class="feed-card-img-wrap"><img src="' + n.imagemNoticia + '" alt="' + n.titulo + '" class="feed-card-img" loading="lazy" onerror="this.parentElement.style.display=\'none\'"></div>'
        : '';

      var avatarHTML = n.fotoPersonagem
        ? '<img src="' + n.fotoPersonagem + '" alt="" class="feed-card-avatar" loading="lazy" onerror="this.style.display=\'none\'">'
        : '';

      card.innerHTML = imgHTML +
        '<div class="feed-card-body">' +
          '<div class="feed-card-header">' +
            avatarHTML +
            '<h2 class="feed-card-title">' + n.titulo + '</h2>' +
          '</div>' +
          '<p class="feed-card-content">' + n.conteudo + '</p>' +
        '</div>';

      grid.appendChild(card);
    });

  } catch(e) {
    console.error('[Feed] Erro ao carregar notícias:', e);
    grid.innerHTML = '';
    empty.style.display = 'block';
  }
}

document.addEventListener('DOMContentLoaded', initFeed);
</script>

